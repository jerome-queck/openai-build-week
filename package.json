{
  "name": "quick-study",
  "productName": "Quick Study",
  "version": "0.1.0",
  "description": "A local-first mathematical learning workbench.",
  "main": "dist/main/main.js",
  "private": true,
  "engines": {
    "node": ">=22 <26"
  },
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"tsc -p tsconfig.main.json --watch --preserveWatchOutput\" \"wait-on tcp:5173 dist/main/main.js && cross-env QUICK_STUDY_DEV_URL=http://127.0.0.1:5173 electron .\"",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "lint": "tsc --noEmit --pretty false",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.main.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "npm run build && electron-forge package --platform=darwin",
    "test:smoke": "playwright test --config=playwright.config.ts",
    "verify": "npm run lint && npm run typecheck && npm test && npm run package && npm run test:smoke"
  },
  "dependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@electron-forge/cli": "7.11.2",
    "@playwright/test": "1.61.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "concurrently": "10.0.3",
    "cross-env": "10.1.0",
    "electron": "43.1.1",
    "jsdom": "26.1.0",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vitest": "4.1.10",
    "wait-on": "9.0.10"
  }
}
